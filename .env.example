# Copie para ".env.local" e preencha. O ".env.local" não vai para o Git.
# Na Vercel: Project → Settings → Environment Variables (use os MESMOS nomes).

# Obrigatório para enviar e-mail de confirmação (painel Resend → API Keys)
RESEND_API_KEY=

# Remetente. Em produção: domínio verificado na Resend, ex.:
# RESEND_FROM=Cerrado Bike Trilhas <noreply@seudominio.com.br>
RESEND_FROM=Cerrado Bike Trilhas <onboarding@resend.dev>

# URL pública do site (links no e-mail e URLs do Mercado Pago)
PUBLIC_SITE_BASE_URL=https://cbt-site.vercel.app

# Já usados pelo projeto (preencha se for rodar confirm-inscription localmente)
# MERCADO_PAGO_ACCESS_TOKEN=
# MERCADO_PAGO_WEBHOOK_SECRET=
